# =================================
# HCLOUD CONFIGURATION
# =================================
HCLOUD_TOKEN=your_hetzner_cloud_token_here
SERVER_NAME=ai-booking-agent
SERVER_TYPE=cx11
SSH_KEY_NAME=default
DATACENTER=nbg1-dc3

# =================================
# CLAUDE API
# =================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =================================
# DATABASE
# =================================
POSTGRES_USER=bookinguser
POSTGRES_PASSWORD=change_this_secure_password
POSTGRES_DB=booking_db

# URL per connessione da app locale (sviluppo)
# DATABASE_URL=postgresql://bookinguser:password@localhost:5432/booking_db

# URL per connessione da produzione (hcloud)
DATABASE_URL=postgresql://bookinguser:change_this_secure_password@postgres:5432/booking_db

# =================================
# BUSINESS CONFIGURATION
# =================================
BUSINESS_NAME=La Tua Azienda
BUSINESS_HOURS_START=09:00
BUSINESS_HOURS_END=18:00
APPOINTMENT_DURATION=30

# =================================
# SERVER CONFIGURATION
# =================================
NODE_ENV=production
PORT=3001
FRONTEND_URL=http://frontend

# =================================
# DEVELOPMENT
# =================================
# Per sviluppo locale, decomenta queste:
# NODE_ENV=development
# DATABASE_URL=postgresql://bookinguser:password@localhost:5432/booking_db
# FRONTEND_URL=http://localhost:5173
