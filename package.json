{
  "name": "ai-booking-agent",
  "version": "1.0.0",
  "description": "AI Agent con Claude API per gestione appuntamenti su hcloud",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "start": "cd backend && npm start",
    "deploy": "bash scripts/deploy.sh",
    "hcloud:setup": "bash scripts/setup-hcloud.sh",
    "hcloud:status": "bash scripts/check-status.sh",
    "hcloud:logs": "bash scripts/helper.sh logs",
    "hcloud:ssh": "bash scripts/helper.sh ssh",
    "hcloud:restart": "bash scripts/helper.sh restart",
    "hcloud:backup": "bash scripts/helper.sh backup",
    "init": "bash scripts/helper.sh init",
    "install:all": "bash scripts/helper.sh install"
  },
  "keywords": ["ai", "chatbot", "booking", "claude", "hcloud"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
